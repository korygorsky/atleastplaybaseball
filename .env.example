# Vercel env vars for /api/corrections.
# Set these in the Vercel project dashboard (Settings → Environment Variables).

# Resend API key (https://resend.com → API Keys)
RESEND_API_KEY=

# Where submissions are delivered
RECIPIENT_EMAIL=kory@gorsky.ca

# Optional: verified Resend sending address. If omitted, uses onboarding@resend.dev
# (which only delivers to the Resend account's own verified email until a domain
# is verified — fine for solo use, but verify a domain to send from kory@gorsky.ca).
# SENDER_EMAIL=Gaffney Park record <noreply@your-verified-domain.com>
