---
import '../styles/site.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'At Least Play Baseball — a public record',
  description = "A single-page record of the public discourse around the proposed cricket pitch at Beryl Gaffney Park in Ottawa.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="page">
      <slot />
    </div>

    <script>
      import '../scripts/main.ts';
    </script>
  </body>
</html>
