---
import SectionHeading from './SectionHeading.astro';

type SourceItem = string | [string, string] | Array<string | { email: string }>;

interface SourceGroup {
  group: string;
  items: SourceItem[];
}

const SOURCES: SourceGroup[] = [
  {
    group: "City of Ottawa — official records",
    items: [
      "Engage Ottawa — Beryl Gaffney Park Cricket Pitch project page.",
      "Engage Ottawa — Beryl Gaffney Park Off-Leash Dog Area.",
      "City of Ottawa — Beryl Gaffney Park Master Plan Update, 2008 (committee record, Planning and Environment Committee).",
      "City of Ottawa — Help conserve Ottawa's turtles (herpetofauna information page).",
      "City of Ottawa — Off-Leash Dog Park directory.",
      "Councillor Wilson Lo (Barrhaven East) — Weekly newsletters, February 24, 2025 and March 11, 2026.",
      "Councillor Glen Gower (Stittsville) — \u201CMore cricket spaces coming to Stittsville.\u201D",
      "Office of the Mayor, City of Ottawa — Public statements re: cricket pitch program (March 2026).",
    ],
  },
  {
    group: "News coverage",
    items: [
      ["CTV News Ottawa", " — \u201CCity of Ottawa planning to create up to 6 new cricket pitches\u201D (March 5, 2026)."],
      ["CTV News Ottawa", " — \u201CCricket pitch proposed for Beryl Gaffney Park.\u201D"],
      ["CTV News Ottawa", " — \u201CCricket boom prompts City of Ottawa to consider creating first dedicated pitch.\u201D"],
      ["CTV News YouTube", " — \u201COttawa dog park to become new cricket pitch\u201D (video; comment section is one of the primary quote sources for Section 5)."],
      ["CBC News", " — \u201COttawa cricket fans make pitch for new places to play\u201D (May 2021)."],
      ["CBC News", " — \u201CHow 3 waves of Asian immigration shaped Ottawa.\u201D"],
      ["CBC News", " — \u201CThe pickleball noise debate has landed in Ottawa.\u201D"],
      ["Ottawa Sports Pages", " — OVCC at Ontario Central T20 (July 2025)."],
      ["Manotick Messenger", " — \u201CNoise Complaints Leave Pickleball Players With No Place To Play\u201D (2023)."],
      ["Turf & Rec", " — \u201COttawa announces plans to build at least five new cricket pitches.\u201D"],
    ],
  },
  {
    group: "Community / forums",
    items: [
      ["Change.org petition", " — \u201CKeep Beryl Gaffney park as an off-leash dog area.\u201D"],
      ["Reddit r/ottawa", " — \u201CKeep Beryl Gaffney Park as is\u201D thread."],
    ],
  },
  {
    group: "Cricket organizations and growth data",
    items: [
      "Ottawa Valley Cricket Council.",
      "Barrhaven Cricket Club.",
      "Kanata Cricket Club.",
      "Monarch Cricket (indoor facility).",
      "Cricket Canada — participation statistics and national growth projections.",
      "Penticton Herald / DV8 Communication — Canadian cricket growth coverage.",
      "City of Toronto — Cricket Strategy.",
    ],
  },
  {
    group: "Environmental",
    items: [
      "Canadian Wildlife Federation — Turtles at risk in Canada.",
      "Ontario Ministry of the Environment, Conservation and Parks — Species at Risk list.",
      "Rideau Valley Conservation Authority.",
      "Rideau Valley Wildlife Sanctuary.",
    ],
  },
  {
    group: "Demographic and historical context",
    items: [
      "Statistics Canada — Ottawa census profiles, 2005–2016 (South Asian population counts).",
      "CBC News — \u201CHow 3 waves of Asian immigration shaped Ottawa.\u201D",
      "Cricket Canada historical records — national governing body established 1892; earliest recorded cricket match on Canadian soil, 1785.",
    ],
  },
  {
    group: "Methodology sources used by this site but not quoted from",
    items: [
      "Sentiment classification approach informed by standard content-analysis practice (verbatim collection, category taxonomy, independent cross-check). Full working memo available on request.",
    ],
  },
];

function isTupleItem(item: SourceItem): item is [string, string] {
  return Array.isArray(item) && item.length === 2 && typeof item[0] === 'string' && typeof item[1] === 'string';
}
---
<section id="about" class="methodology">
  <div class="container">
    <div class="eyebrow">Section 08 · About / Methodology</div>
    <SectionHeading id="about">How this page <em>was assembled.</em></SectionHeading>

    <h3>Why this site exists</h3>
    <p>
      This site was compiled by a private citizen who noticed a pattern in the public commentary about the Beryl Gaffney Park cricket pitch and wanted to find out whether the evidence supported what they were reading. The site is the product of that investigation.
    </p>
    <p>
      The author has no affiliation with the City of Ottawa, the Ottawa Valley Cricket Council, any cricket club, any community association, any councillor, any political campaign, or any media organization. The site is not monetized, carries no advertising, and does not collect reader data beyond aggregate traffic.
    </p>

    <h3>How the site was built</h3>
    <p>
      <em>Primary sources.</em> Every factual claim about the project, the park, or the City's consultation is linked to a primary source — Engage Ottawa, the 2008 master plan update, City Councillor communications, or named news coverage. Where a primary source was unavailable or behind a login wall, the site says so rather than citing secondary reporting as if it were primary.
    </p>
    <p>
      <em>Quote collection.</em> Verbatim public comments were collected from: the comment section of the CTV News YouTube video &ldquo;Ottawa dog park to become new cricket pitch&rdquo;; the r/ottawa Reddit thread &ldquo;Keep Beryl Gaffney Park as is&rdquo;; the comment thread of the Change.org petition &ldquo;Keep Beryl Gaffney park as an off-leash dog area&rdquo;; and public posts (and their public comment threads) by Mayor Mark Sutcliffe, Councillor Wilson Lo, and Councillor Glen Gower.
    </p>
    <p>
      Facebook content inside closed community groups was <strong>not</strong> used as a primary source. Where secondary reporting describes patterns inside those groups, the patterns are described — but individual quotes are not reproduced.
    </p>
    <p>
      <em>Classification.</em> Each quote in Section 5 was classified into one of five categories: <em>Substantive, Skeptical, Cultural, Coded,</em> or <em>Pushback</em>. The classification is based on the language of the quote itself. No inference is made about the commenter's identity, intent, or character.
    </p>
    <p>
      <em>Verification.</em> Each direct quote reproduced on this site was cross-checked against the original source at the time of publication. Screenshots were taken as backup where the source permitted it. Where a comment was referenced in secondary reporting but could not be verbatim-verified, the comment is described in aggregate but not quoted.
    </p>
    <p>
      <em>Names.</em> Residents quoted by name in news coverage appear only in Section 4 (The Concerns), and only in the frame of the public-record concerns they raised. No named resident appears in Section 5 (The Comments). No private Facebook account is named anywhere on the site. No screenshot on this site identifies any individual.
    </p>

    <h3>Corrections</h3>
    <p>
      If you believe something on this site is factually wrong, missing a necessary caveat, or quoted out of context — or if you have primary-source material that would improve the record — a corrections channel is being set up and will be listed here once active. Every message will be read. Meaningful corrections are applied promptly and are noted with the date of the change.
    </p>

    <h3>Anonymity</h3>
    <p>
      The author of this site has chosen to publish anonymously. The reasoning is simple: the site is about public commentary in a particular community, and naming the author would make the site about the author. Anonymity is not a screen for opinions that would not survive being named; the site's claims stand or fall on the sources cited, and the author is prepared to stand behind those sources if required.
    </p>

    <div id="sources" style="margin-top: 72px;">
      <div class="eyebrow" style="color: var(--ink-40); border-top-color: var(--rideau);">Section 09 · Sources</div>
      <SectionHeading id="sources">The record.</SectionHeading>
      <p style="margin-bottom: 0;">
        Every source below is linked to the original record. Where an archived copy exists on the Wayback Machine or archive.today, it is listed alongside the live link on the live site.
      </p>

      {SOURCES.map((grp) => (
        <div class="sources-group">
          <h4>{grp.group}</h4>
          <ul class="sources-list">
            {grp.items.map((item) => {
              if (typeof item === 'string') {
                return (
                  <li>
                    <a href="#" class="src-link">
                      <span>{item}</span>
                      <svg aria-hidden="true" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left: 6px; vertical-align: baseline; flex-shrink: 0;">
                        <path d="M7 17L17 7"/>
                        <path d="M8 7h9v9"/>
                      </svg>
                    </a>
                  </li>
                );
              }
              if (isTupleItem(item)) {
                return (
                  <li>
                    <a href="#" class="src-link">
                      <span><strong>{item[0]}</strong>{item[1]}</span>
                      <svg aria-hidden="true" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left: 6px; vertical-align: baseline; flex-shrink: 0;">
                        <path d="M7 17L17 7"/>
                        <path d="M8 7h9v9"/>
                      </svg>
                    </a>
                  </li>
                );
              }
              return (
                <li>
                  {item.map((part) => {
                    if (typeof part === 'string') return <Fragment>{part}</Fragment>;
                    if (part && part.email) return <span class="email-text">{part.email}</span>;
                    return null;
                  })}
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer-line">
      Last updated 2026-04-18 · Anonymous · Non-commercial
    </div>
  </div>
</section>
